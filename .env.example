# H Assistant Configuration

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Default LLM provider: claude | openai | gemini | claude-code
H_DEFAULT_LLM_PROVIDER=claude

# Database
H_DB_PATH=./data/h.db

# API Server
H_API_PORT=3100
H_API_HOST=localhost

# Telegram Bot
H_TELEGRAM_BOT_TOKEN=
H_TELEGRAM_ALLOWED_USER_IDS=

# Logging
H_LOG_LEVEL=info
