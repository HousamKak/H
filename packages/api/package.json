{
  "name": "@h/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@h/types": "workspace:*",
    "@h/events": "workspace:*",
    "@h/db": "workspace:*",
    "@h/orchestrator": "workspace:*",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "ws": "^8.18.0",
    "express-rate-limit": "^7.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0"
  }
}
